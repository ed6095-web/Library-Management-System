{
  "buildCommand": "echo 'Static frontend'",
  "outputDirectory": "frontend",
  "public": false,
  "functions": {
    "frontend/**": {
      "runtime": "static"
    }
  },
  "routes": [
    {
      "src": "/(.+)",
      "dest": "/index.html",
      "status": 200
    }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=3600"
        }
      ]
    }
  ],
  "env": {
    "REACT_APP_API_URL": "@api_url"
  }
}
